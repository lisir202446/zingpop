      "npm": "@ai-sdk/openai-compatible",
      "env": ["MYTOKENLAND_BACKUP_A_API_KEY"],
      "models": {
        "glm-5.1": {
          "name": "GLM 5.1 Backup A",
          "tool_call": true,
