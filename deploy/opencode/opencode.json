{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "enabled_providers": ["zai-glm"],
  "model": "zai-glm/glm-5-turbo",
  "small_model": "zai-glm/glm-5-turbo",
  "agent": {
    "build": {
      "model": "zai-glm/glm-5-turbo"
    }
  },
  "provider": {
    "zai-glm": {
      "name": "Z.AI GLM",
      "npm": "@ai-sdk/openai-compatible",
      "env": ["ZAI_API_KEY"],
      "models": {
        "glm-4.5-air": {
          "name": "GLM 4.5 Air",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "glm-4.6": {
          "name": "GLM 4.6",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "glm-4.7": {
          "name": "GLM 4.7",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "glm-5": {
          "name": "GLM 5",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "glm-5-turbo": {
          "name": "GLM 5 Turbo",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "glm-5.1": {
          "name": "GLM 5.1",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        }
      },
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/paas/v4",
        "timeout": 300000,
        "chunkTimeout": 60000
      }
    }
  }
}
