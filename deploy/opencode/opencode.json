{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "enabled_providers": [
    "mytokenland-deepseek",
    "mytokenland-glm",
    "mytokenland-kimi",
    "mytokenland-minimax",
    "mytokenland-backup-a",
    "mytokenland-backup-b"
  ],
  "model": "mytokenland-glm/glm-5.1",
  "small_model": "mytokenland-glm/glm-5.1",
  "agent": {
    "build": {
      "model": "mytokenland-glm/glm-5.1"
    }
  },
  "provider": {
    "mytokenland-deepseek": {
      "name": "MyTokenLand DeepSeek",
      "npm": "@ai-sdk/openai-compatible",
      "env": ["MYTOKENLAND_API_KEY"],
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        }
      },
      "options": {
        "baseURL": "https://api.mytokenland.com/v1",
        "timeout": 300000,
        "chunkTimeout": 60000
      }
    },
    "mytokenland-glm": {
      "name": "MyTokenLand GLM",
      "npm": "@ai-sdk/openai-compatible",
      "env": ["MYTOKENLAND_GLM_API_KEY"],
      "models": {
        "glm-5.1": {
          "name": "GLM 5.1",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        }
      },
      "options": {
        "baseURL": "https://api.mytokenland.com/v1",
        "timeout": 300000,
        "chunkTimeout": 60000
      }
    },
    "mytokenland-kimi": {
      "name": "MyTokenLand Kimi",
      "npm": "@ai-sdk/openai-compatible",
      "env": ["MYTOKENLAND_KIMI_API_KEY"],
      "models": {
        "kimi-k2.6": {
          "name": "Kimi K2.6",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        }
      },
      "options": {
        "baseURL": "https://api.mytokenland.com/v1",
        "timeout": 300000,
        "chunkTimeout": 60000
      }
    },
    "mytokenland-minimax": {
      "name": "MyTokenLand MiniMax",
      "npm": "@ai-sdk/openai-compatible",
      "env": ["MYTOKENLAND_MINIMAX_API_KEY"],
      "models": {
        "MiniMax-M2.7": {
          "name": "MiniMax M2.7",
          "tool_call": true,
