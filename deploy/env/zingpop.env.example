# Copy to /etc/zingpop/zingpop.env on the server and replace placeholders.

ZINGPOP_DOMAIN=www.zingpop.cn
ZINGPOP_APP_DOMAIN=app.zingpop.cn
ZINGPOP_REPO=/opt/zingpop/current
ZINGPOP_WORKSPACE_ROOT=/srv/zingpop/workspaces
# Authenticated workbench directories resolve to:
# "$ZINGPOP_WORKSPACE_ROOT/<workspace_id>/projects/${ZINGPOP_DEFAULT_PROJECT_ID:-default}".
ZINGPOP_DEFAULT_PROJECT_ID=default
# Legacy fallback used only when no workspace id is available. Do not point
# public multi-user production users at this shared directory.
# ZINGPOP_DEFAULT_WORKSPACE_DIR=/srv/zingpop/workspaces/default
ZINGPOP_PORT=4096
ZINGPOP_OPENCODE_BIN=/opt/zingpop/bin/opencode
ZINGPOP_CONSOLE_HOST=127.0.0.1
ZINGPOP_CONSOLE_PORT=3000
ZINGPOP_BACKUP_ROOT=/srv/zingpop/backups
ZINGPOP_BACKUP_RETENTION_DAYS=14
ZINGPOP_CERT_MIN_DAYS=21
ZINGPOP_DISK_MIN_FREE_PERCENT=15
# Optional webhook for production-health-check alerts.
# ZINGPOP_ALERT_WEBHOOK_URL=https://example.com/ops-alert-webhook
APP_STAGE=production
ZEN_SESSION_SECRET=replace-with-a-long-random-secret

# Existing opencode server authentication.
# Keep this password private. Do not leave production without it.
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=change-this-before-production
OPENCODE_DB=/srv/zingpop/data/opencode.db
OPENCODE_CONFIG_DIR=/srv/zingpop/config
HOME=/srv/zingpop
XDG_DATA_HOME=/srv/zingpop/data
XDG_CONFIG_HOME=/srv/zingpop/config
XDG_CACHE_HOME=/srv/zingpop/cache
XDG_STATE_HOME=/srv/zingpop/state

# Product home/auth database. Prefer a dedicated MySQL user in production.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=zingpop_app
MYSQL_PASSWORD=replace-with-database-password
MYSQL_DATABASE=opencode
MYSQL_SSL=false

# Needed when www.zingpop.cn handles login and app.zingpop.cn is protected by
# Nginx auth_request.
AUTH_COOKIE_DOMAIN=.zingpop.cn

# Optional: pin one workspace when running a single-tenant instance.
# OPENCODE_WORKSPACE_ID=zingpop-main

# Keep embedded Web UI enabled. It lets one backend origin serve the workbench
# and makes the browser default backend equal to location.origin.
OPENCODE_DISABLE_EMBEDDED_WEB_UI=false

# Huawei Cloud Marketplace APIG SMS. Use AppCode when the marketplace request
# example shows `X-Apig-AppCode`. The content template must include an approved
# provider signature in `【】` format.
# SMS_PROVIDER=huawei_apig
# HUAWEI_APIG_SMS_URL=https://cdcxsms.apistore.huaweicloud.com/chuangxinsms/dxjk
# HUAWEI_APIG_APPCODE=replace-with-marketplace-appcode
# HUAWEI_APIG_SMS_CONTENT_TEMPLATE=【线粒体（广州）互联网有限公司】验证码：{code}。您正在进行身份验证，需要进行验证码校验（3分钟内有效），请勿向任何人提供此验证码。
# HUAWEI_APIG_SMS_CONTENT_PARAM=content
# HUAWEI_APIG_SMS_MOBILE_PARAM=mobile
# HUAWEI_APIG_STAGE=RELEASE

# Huawei APIG SDK-HMAC mode. Use this only when the request example requires
# AppKey/AppSecret signing instead of `X-Apig-AppCode`.
# HUAWEI_APIG_APP_KEY=replace-with-apig-app-key
# HUAWEI_APIG_APP_SECRET=replace-with-apig-app-secret
