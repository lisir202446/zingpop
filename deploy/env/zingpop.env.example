# Copy to /etc/zingpop/zingpop.env on the server and replace placeholders.

ZINGPOP_DOMAIN=www.zingpop.cn
ZINGPOP_APP_DOMAIN=app.zingpop.cn
ZINGPOP_REPO=/opt/zingpop/current
ZINGPOP_WORKSPACE_ROOT=/srv/zingpop/workspaces
ZINGPOP_PORT=4096
ZINGPOP_OPENCODE_BIN=/opt/zingpop/bin/opencode

# Existing opencode server authentication.
# Keep this password private. Do not leave production without it.
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=change-this-before-production
OPENCODE_DB=/srv/zingpop/data/opencode.db
OPENCODE_CONFIG_DIR=/srv/zingpop/config

# Needed when www.zingpop.cn handles login and app.zingpop.cn is protected by
# Nginx auth_request.
AUTH_COOKIE_DOMAIN=.zingpop.cn

# Optional: pin one workspace when running a single-tenant instance.
# OPENCODE_WORKSPACE_ID=zingpop-main

# Keep embedded Web UI enabled. It lets one backend origin serve the workbench
# and makes the browser default backend equal to location.origin.
OPENCODE_DISABLE_EMBEDDED_WEB_UI=false
